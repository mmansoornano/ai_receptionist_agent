# Copy to .env and fill in values. Do not commit .env.

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

BACKEND_API_BASE_URL=http://localhost:8000

AGENT_API_PORT=8001
AGENT_API_HOST=0.0.0.0

# Optional: comma-separated origins for browser demos (see api_server CORS)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Set to 1 only for local debug: log full phone/customer ids and full messages at INFO
# AGENT_LOG_PII=1

# Google Calendar (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
DEFAULT_FROM_EMAIL=noreply@example.com

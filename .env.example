# Copy to .env and fill in values. Do not commit .env.

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LLM-as-judge (runs after every scenario graph turn in tests/integration). Same Ollama-first /
# OpenAI-fallback idea as the agent unless you override JUDGE_LLM_PROVIDER.
# JUDGE_LLM_PROVIDER=openai
# JUDGE_OLLAMA_MODEL=llama3.1:8b
# JUDGE_OPENAI_MODEL=gpt-4o-mini
# AGENT_SKIP_LLM_JUDGE=1   # break-glass: skip judge calls (not recommended)

# Input guard (runs before router). Optional model overrides; defaults match main LLM.
# GUARD_OLLAMA_MODEL=llama3.1:8b
# GUARD_OPENAI_MODEL=gpt-4o-mini
# AGENT_SKIP_GUARD_LLM=1   # unknown lines allowed (only YAML blocklist refuses)

BACKEND_API_BASE_URL=http://localhost:8000

AGENT_API_PORT=8001
AGENT_API_HOST=0.0.0.0

# Optional: comma-separated origins for browser demos (see api_server CORS)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Set to 1 only for local debug: log full phone/customer ids and full messages at INFO
# AGENT_LOG_PII=1

# Google Calendar (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
DEFAULT_FROM_EMAIL=noreply@example.com
